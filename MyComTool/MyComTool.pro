QT += core gui widgets serialport charts network core5compat

CONFIG += c++17
TARGET = SerialChartTool
TEMPLATE = app

# 源文件
SOURCES += main.cpp frmcomtool.cpp \
    api/appconfig.cpp api/appdata.cpp api/qthelper.cpp api/qthelperdata.cpp

HEADERS += frmcomtool.h head.h \
    api/appconfig.h api/appdata.h api/qthelper.h api/qthelperdata.h

FORMS += frmcomtool.ui

INCLUDEPATH += $$PWD/api

# Default rules for deployment.
qnx: target.path = /tmp/$${TARGET}/bin
else: unix:!android: target.path = /opt/$${TARGET}/bin
!isEmpty(target.path): INSTALLS += target

